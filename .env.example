# PostgreSQL (run: docker compose up -d)
DATABASE_URL="postgresql://finance:finance@localhost:5433/finance_tracker"

# Session signing — at least 16 characters
AUTH_SECRET="replace-with-a-long-random-string-at-least-16-chars"

# App URL (password reset, OAuth, emails)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (Resend) — https://resend.com
# RESEND_API_KEY=
# EMAIL_FROM="FinanceTracker <onboarding@yourdomain.com>"

# Google OAuth — https://console.cloud.google.com
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Cron protection for bill reminders
# CRON_SECRET=
